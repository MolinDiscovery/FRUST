\n                                    fontSize:12\\n                                }\\n                            );\\n                            viewer._distLabels[key]=lbl;\\n                        }\\n                        viewer._picks = [];\\n                    }\\n                }\\n                // Click: toggle label\\n                else {\\n                    if(atom.label) {\\n                        viewer.removeLabel(atom.label);\\n                        delete atom.label;\\n                    } else {\\n                        atom.label = viewer.addLabel(\\n                            atom.index,\\n                            {\\n                                position:atom,\\n                                backgroundColor:'white',\\n                                fontColor:'black',\\n                                fontSize:12\\n                            }\\n                        );\\n                    }\\n                }\\n                viewer.render();\\n            }\");\n",
